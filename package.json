{
  "name": "led-ppfd-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.14.1"
  },
  "scripts": {
    "dev": "vite",
    "test": "node --import ./test/register-tests.mjs --test test/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:budget": "node scripts/check-bundle-budget.mjs",
    "check:types": "vue-tsc --noEmit",
    "test:components": "vitest run",
    "check": "npm run lint && npm run format:check && npm run check:types && npm test && npm run test:components && npm run build && npm run build:budget",
    "test:browser": "playwright test",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.2"
  }
}
